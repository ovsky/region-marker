{
  "name": "regionmarker",
  "displayName": "Region Marker",
  "description": "Simple extensions for better regions visibility.",
  "version": "0.3.6",
  "publisher": "awwsky",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Linters",
    "Snippets",
    "Formatters",
    "Debuggers",
    "Testing",
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "colors": [
      {
        "id": "regionmarker.background",
        "description": "RegionMarker Background Color.",
        "defaults": {
          "dark": "#ae00ff2d",
          "light": "#ae00ff2d",
          "highContrast": "#ae00ff"
        }
      },
      {
        "id": "regionmarker.foreground",
        "description": "RegionMarker Foreground Color.",
        "defaults": {
          "dark": "#ffffff70",
          "light": "#ffffff70",
          "highContrast": "#ffffff"
        }
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Region Marker",
      "properties": {
        "regionmarker.background": {
          "type": "string",
          "default": "#ae00ff2d",
          "description": "RegionMarker Background Color."
        },
        "regionmarker.foreground": {
          "type": "string",
          "default": "#ffffff70",
          "description": "RegionMarker Foreground Color."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "lint": "eslint . --ext .ts,.tsx",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^12.12.0",
    "@typescript-eslint/eslint-plugin": "^3.0.2",
    "@typescript-eslint/parser": "^3.0.2",
    "eslint": "^7.1.0",
    "typescript": "^4.5.4",
    "@types/vscode": "^1.13.0"
  }
}
